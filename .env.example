# ── Required ──────────────────────────────────────────────────────────────────
PORT=3001
DB_PATH=./data/altlas.db

# URL the backend uses for CORS and OAuth redirects back to the frontend.
# Local dev (Vite):        FRONTEND_URL=http://localhost:5173
# Docker production:       FRONTEND_URL=http://localhost
FRONTEND_URL=http://localhost:5173

# ── Battle.net OAuth (optional) ───────────────────────────────────────────────
# Leave blank to disable all Battle.net features.
BNET_CLIENT_ID=
BNET_CLIENT_SECRET=
BNET_REGION=us

# Redirect URI registered in your Battle.net app.
# Local dev:          BNET_REDIRECT_URI=http://localhost:3001/api/auth/callback
# Docker production:  BNET_REDIRECT_URI=http://localhost/api/auth/callback
BNET_REDIRECT_URI=http://localhost:3001/api/auth/callback
